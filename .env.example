# Minecraft
MC_VERSION=1.21.1
NEOFORGE_VERSION=21.1.146

# World
LEVEL_NAME=world
LEVEL_SEED=-3361685360695458093
DIFFICULTY=hard
GAMEMODE=survival

# Server
MEMORY=5G
MAX_PLAYERS=10
VIEW_DISTANCE=10
SIMULATION_DISTANCE=8
MOTD=Frost SMP

# Authentication
ONLINE_MODE=TRUE
WHITELIST=
OPS=

# Gameplay
SPAWN_PROTECTION=0
PVP=TRUE
ENABLE_COMMAND_BLOCK=FALSE
MAX_TICK_TIME=-1

# Tunnel (playit.gg — no port forwarding needed)
# Leave empty for first run — the container will print a claim URL in the logs.
# Or select "Linux" as the agent type in the dashboard to get a secret key.
PLAYIT_SECRET_KEY=

# JVM
JVM_OPTS=
